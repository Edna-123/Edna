:root {
    --primary: #1a5d1a;
    --secondary: #f4ba5f;
    --bg: #f9fbf9;
}

body { font-family: 'Segoe UI', sans-serif; background: var(--bg); color: #333; line-height: 1.8; }
.container { max-width: 1200px; margin: auto; padding: 40px 20px; }
.hidden { display: none; }

/* Calculator Styling */
.calc-grid { background: white; padding: 30px; border-radius: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.05); }
input, select, button { padding: 15px; margin: 10px; border-radius: 8px; border: 1px solid #ddd; }
button { background: var(--primary); color: white; border: none; cursor: pointer; font-weight: bold; }

/* Clickable Library Cards */
.clickable-card { 
    background: white; 
    padding: 20px; 
    border-radius: 12px; 
    margin-bottom: 10px; 
    cursor: pointer; 
    transition: 0.3s;
    border-left: 5px solid var(--secondary);
}
.clickable-card:hover { transform: scale(1.01); }
.hidden-detail { display: none; padding-top: 20px; color: #666; border-top: 1px solid #eee; }

/* Footer */
footer { background: #111; color: white; padding: 60px 0; margin-top: 100px; }
