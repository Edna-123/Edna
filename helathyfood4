function calculateTDEE() {
    const weight = parseFloat(document.getElementById('weight').value);
    const height = parseFloat(document.getElementById('height').value);
    const age = parseFloat(document.getElementById('age').value);
    const gender = document.getElementById('gender').value;

    if (!weight || !height || !age) {
        alert("Please fill in all details.");
        return;
    }

    // BMR Calculation
    let bmr;
    if (gender === "male") {
        bmr = (10 * weight) + (6.25 * height) - (5 * age) + 5;
    } else {
        bmr = (10 * weight) + (6.25 * height) - (5 * age) - 161;
    }

    const tdee = Math.round(bmr * 1.375); // Light Activity factor
    document.getElementById('tdee-val').innerText = tdee;
    document.getElementById('results').classList.remove('hidden');
    document.getElementById('tdee-advice').innerText = 
        `To lose weight, aim for ${tdee - 500} kcal. To build muscle, aim for ${tdee + 300} kcal.`;
}

function toggleDetail(id) {
    const el = document.getElementById(id);
    el.style.display = (el.style.display === 'block') ? 'none' : 'block';
}
