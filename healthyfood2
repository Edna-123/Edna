/* Container for the detail page */
.detail-container {
    max-width: 1000px;
    margin: 40px auto;
    padding: 0 20px;
}

.category-tag {
    background: #e8f5e9;
    color: #2e7d32;
    padding: 5px 12px;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: bold;
    text-transform: uppercase;
}

.food-header h1 {
    font-size: 2.5rem;
    margin: 10px 0;
    color: #1b5e20;
}

/* Grid for the content */
.detail-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 30px;
    margin: 30px 0;
}

.science-card, .benefits-list {
    background: #ffffff;
    padding: 25px;
    border-radius: 12px;
    border: 1px solid #e0e0e0;
}

.warning-box {
    margin-top: 20px;
    padding: 15px;
    background: #fff3e0;
    border-left: 5px solid #ff9800;
    font-size: 0.9rem;
}

/* Table styling for details */
.detail-table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 20px;
}

.detail-table th, .detail-table td {
    padding: 15px;
    text-align: left;
    border-bottom: 1px solid #eee;
}

.detail-table th {
    background-color: #f5f5f5;
    color: #333;
}
